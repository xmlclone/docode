   "id": "426f98ff-b95b-41f1-8684-c9cd7f3fc1aa",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "1\n",
      "1\n"
     ]
    }
   ],
   "source": [
    "from functools import partial\n",
    "\n",
    "def f1(a, b, c):\n",
    "    return a + b + c\n",
    "\n",
    "f2 = partial(f1, b=0, c=0)\n",
    "print(f2(1))\n",
    "\n",
    "# 如果定义的参数未按f1的顺序排序，那么在调用f3时，需要通过关键字参数进行调用，不能直接传递参数，否则会认为是赋值给参数a\n",
    "f3 = partial(f1, a=0, b=0)\n",
    "print(f3(c=1))"
   ]
  },
